# API base URL. Use SAME_ORIGIN (or leave empty) when deploying on Netlify so
# /api/* is proxied to the backend via netlify.toml. For local dev with vite
# proxy, also use SAME_ORIGIN and run the backend on localhost:3000.
VITE_API_BASE_URL=SAME_ORIGIN

# Optional: override the dev proxy target (defaults to http://localhost:3000)
# VITE_DEV_API_PROXY=http://localhost:3000
